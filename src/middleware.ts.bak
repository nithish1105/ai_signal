import { NextResponse } from 'next/server';
import type { NextRequest } from 'next/server';
import * as jose from 'jose'; // Use jose since jsonwebtoken is not supported in Next.js edge runtime

const JWT_SECRET = new TextEncoder().encode(
  process.env.JWT_SECRET || 'fallback-secret-access-token-key-2026'
);

export async function middleware(request: NextRequest) {
  const { pathname } = request.nextUrl;

  // Define protected page routes and protected API routes
  const isProtectedPage = pathname.startsWith('/dashboard');
  const isProtectedApi = pathname.startsWith('/api/saved-colleges');

  if (isProtectedPage || isProtectedApi) {
    const token = request.cookies.get('access_token')?.value;

    if (!token) {
      if (isProtectedApi) {
        return NextResponse.json(
          { error: 'Unauthorized: Missing access token' },
          { status: 401 }
        );
      }
      // Redirect to login page and preserve redirect URL
      const url = new URL('/auth/login', request.url);
      url.searchParams.set('redirect', pathname);
      return NextResponse.redirect(url);
    }

    try {
      // Use jose for edge runtime verification
      await jose.jwtVerify(token, JWT_SECRET);
      return NextResponse.next();
    } catch (error) {
      if (isProtectedApi) {
        return NextResponse.json(
          { error: 'Unauthorized: Invalid or expired access token' },
          { status: 401 }
        );
      }
      
      // If access token is expired, redirect to login (or refresh flow can be handled on client)
      const url = new URL('/auth/login', request.url);
      url.searchParams.set('redirect', pathname);
      return NextResponse.redirect(url);
    }
  }

  return NextResponse.next();
}

export const config = {
  matcher: ['/dashboard/:path*', '/api/saved-colleges/:path*'],
};
